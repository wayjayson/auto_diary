# ============================================================
# auto_dairy – Environment Configuration
# ============================================================
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# ============================================================

# DeepSeek API key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Full path to your Obsidian vault root directory
# Windows example: C:\Users\YourName\Documents\ObsidianVault
OBSIDIAN_VAULT_PATH=C:\Users\YourName\Documents\ObsidianVault

# Sub-folder inside the vault where diary files are written
DIARY_FOLDER=Daily

# Daily trigger time in HH:MM (24-hour format)
# Used by --schedule mode and by setup_scheduler.ps1
SCHEDULE_TIME=23:00
